case "${1:-status}" in
  status)              shift 2>/dev/null || true; cmd_status "$@";;
  branches|br)         shift; cmd_branches "$@";;
  prs|pulls)           shift; cmd_prs "$@";;
  log|activity)        shift; cmd_log "$@";;
  health|hunt)         shift; cmd_health "$@";;
  sync)                shift; cmd_sync "$@";;
  tidy)                shift; cmd_tidy "$@";;
  branch)              shift; cmd_branch "$@";;
  pr)                  shift; cmd_pr "$@";;
  help|-h|--help)      cmd_help;;
  -V|--version|version) printf "vegtam %s\n" "$VERSION";;
  *) printf "\n  ${R}unknown command: %s${X}\n" "$1"; cmd_help; exit 1;;
esac
