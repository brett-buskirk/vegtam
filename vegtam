#!/usr/bin/env bash
# vegtam — the wanderer. A pocket CLI for whatever repo you're standing in.
#
# Odin walks Midgard in disguise under the name Vegtam; this tool is that mode.
# It operates on exactly ONE repository — the one your shell is in right now —
# derived live from the local .git and its GitHub remote. No config, no estate
# model, no stored state. Drop it in ~/.local/bin and run it in any repo, on any
# machine, and it just works.
#
#   vegtam [status]        one-screen briefing on the current repo
#   vegtam help            the menu · vegtam <command> help  for per-command detail
#
# Deps: bash + git are required; gh + jq power the GitHub-backed sections and are
# optional — every remote call degrades to a quiet note when they're missing, the
# remote isn't GitHub, or you lack access. Vegtam owns nothing and mutates nothing
# it isn't explicitly asked to; it is built to be safe in repositories you don't own.
# shellcheck disable=SC2059  # color vars are fixed ANSI codes, deliberately embedded in format strings
set -uo pipefail

VERSION="1.0.2"

# ── palette — color only on a TTY, and never when NO_COLOR is set ─────────────
# Same convention as the rest of the pack: if stdout isn't a terminal (piped,
# redirected) or NO_COLOR is present, the escapes collapse to empty strings and
# the output is plain text.
if [ -t 1 ] && [ -z "${NO_COLOR:-}" ]; then
  R=$'\e[31m'; G=$'\e[32m'; Y=$'\e[33m'; C=$'\e[36m'; M=$'\e[35m'; DIM=$'\e[2m'; BD=$'\e[1m'; X=$'\e[0m'
else R=; G=; Y=; C=; M=; DIM=; BD=; X=; fi

# ── small helpers ─────────────────────────────────────────────────────────────
have(){ command -v "$1" >/dev/null 2>&1; }                    # is a tool on PATH?
is_help(){ case "${1:-}" in help|-h|--help) return 0;; *) return 1;; esac; }
note(){ printf "    ${DIM}%s${X}\n" "$1"; }                    # a dim aside when a section can't render

# The inspect views can emit machine-readable output with --json. jq builds it (so
# escaping is always correct); without jq we refuse cleanly rather than hand-roll
# JSON. num() normalizes a value to a bare JSON number, or "null" when it's not one —
# handy for feeding --argjson from fields that may be empty (no upstream, no access).
json_ok(){ have jq && return 0; printf "  ${R}--json needs jq${X} ${DIM}(install jq, or drop --json for the human view).${X}\n" >&2; return 1; }
num(){ [[ "${1:-}" =~ ^-?[0-9]+$ ]] && printf '%s' "$1" || printf 'null'; }

# Compact a git relative date ("2 hours ago" -> "2h") so a whole status line fits
# on one row. Mirrors huginn's status renderer.
short(){ sed -E 's/ years?/y/;s/ months?/mo/;s/ weeks?/w/;s/ days?/d/;s/ hours?/h/;s/ minutes?/m/;s/ seconds?/s/;s/ ago//;s/ //g' <<<"${1:-}"; }

# Compact age of a unix timestamp ("3d", "2w"). Companion to short(): that one
# reshapes git's worded relative dates, this one works straight off an epoch.
age_short(){
  local now diff; now="$(date +%s)"; diff=$(( now - ${1:-0} )); [ "$diff" -lt 0 ] && diff=0
  if   [ "$diff" -lt 3600 ];    then printf '%dm'  $(( diff/60 ))
  elif [ "$diff" -lt 86400 ];   then printf '%dh'  $(( diff/3600 ))
  elif [ "$diff" -lt 604800 ];  then printf '%dd'  $(( diff/86400 ))
  elif [ "$diff" -lt 2592000 ]; then printf '%dw'  $(( diff/604800 ))
  else                               printf '%dmo' $(( diff/2592000 )); fi
}

# Turn a compact window (6h, 3d, 2w, 1mo) into a `git log --since` phrase. Returns
# non-zero on a malformed window so the caller can complain instead of guessing.
since_to_gitdate(){
  [[ "${1:-}" =~ ^([0-9]+)(mo|[dwh])$ ]] || return 1
  local n="${BASH_REMATCH[1]}" u="${BASH_REMATCH[2]}"
  case "$u" in
    h)  printf '%s hours ago'  "$n";;
    d)  printf '%s days ago'   "$n";;
    w)  printf '%s weeks ago'  "$n";;
    mo) printf '%s months ago' "$n";;
  esac
}

# The repo's default branch — read from the local origin/HEAD pointer, else "main".
default_branch(){ local d; d="$(git symbolic-ref --short refs/remotes/origin/HEAD 2>/dev/null | sed 's#^origin/##')"; printf '%s' "${d:-main}"; }

# A ref to test "is this merged?" against: prefer origin/<default> (what's actually
# merged upstream), fall back to the local default branch, then HEAD.
default_ref(){
  local d="${1:-main}"
  if   git rev-parse --verify -q "refs/remotes/origin/$d" >/dev/null 2>&1; then printf 'origin/%s' "$d"
  elif git rev-parse --verify -q "refs/heads/$d"          >/dev/null 2>&1; then printf '%s' "$d"
  else printf 'HEAD'; fi
}

# The current GitHub login, resolved once and memoized (used to highlight "your"
# PRs). Empty when gh is missing or unauthenticated — callers treat that as "unknown".
GH_LOGIN=""; GH_LOGIN_SET=0
gh_login(){ [ "$GH_LOGIN_SET" = 1 ] || { GH_LOGIN="$(gh api user --jq .login 2>/dev/null || true)"; GH_LOGIN_SET=1; }; printf '%s' "$GH_LOGIN"; }

# Boil a bag of CI state/conclusion words down to one verdict: pass|fail|pending|none.
# Shared by status (a commit's checks) and prs (a PR's statusCheckRollup). Tokenizes
# to alpha words first so commas, brackets, and casing don't matter.
classify_ci(){
  local all; all="$(printf '%s\n' "${1:-}" | grep -oiE '[A-Za-z_]+' || true)"
  [ -z "$all" ] && { echo none; return; }
  grep -qiE 'fail|cancel|timed_out|action_required|error' <<<"$all" && { echo fail; return; }
  grep -qiE 'pending|queued|in_progress|waiting|expected|stale|null' <<<"$all" && { echo pending; return; }
  echo pass
}

# ── health helpers (used by the security & freshness view) ────────────────────
plural(){ [ "${1:-0}" = 1 ] && printf '' || printf 's'; }
sev_color(){ case "$1" in critical) printf '%s' "$BD$R";; high) printf '%s' "$R";; medium) printf '%s' "$Y";; *) printf '%s' "$DIM";; esac; }
# A dependency manifest filename -> its ecosystem label (npm, pip, …).
manifest_ecosystem(){ case "$1" in
  package.json) echo npm;; requirements.txt|Pipfile|pyproject.toml) echo pip;; Gemfile) echo bundler;;
  go.mod) echo gomod;; Cargo.toml) echo cargo;; composer.json) echo composer;; pom.xml) echo maven;;
  build.gradle|build.gradle.kts) echo gradle;; *.csproj) echo nuget;;
esac; }
# Leading major version from a tag ("v4.1.0"/"4.1.0" -> "4"); empty if not version-shaped.
majnum(){ local v="${1:-}"; v="${v#v}"; v="${v#V}"; [[ "$v" =~ ^([0-9]+) ]] && printf '%s' "${BASH_REMATCH[1]}"; }
# The manifest filenames health looks for, and the dirs it won't descend into.
MANIFEST_FIND_EXPR=( -type f \( -name package.json -o -name requirements.txt -o -name Pipfile \
  -o -name pyproject.toml -o -name Gemfile -o -name go.mod -o -name Cargo.toml -o -name composer.json \
  -o -name pom.xml -o -name build.gradle -o -name build.gradle.kts -o -name '*.csproj' \) )

# ── repo resolution — everything Vegtam knows comes from the current directory ─
# Confirm we're inside a git work tree, find its root, and (best-effort) resolve a
# github.com owner/name from the remotes. Populates the globals below; SLUG is left
# empty for a non-GitHub or remote-less repo, in which case the git-only views
# still work and the gh-backed ones degrade gracefully.
RROOT=""      # absolute path to the work-tree root
REPO_NAME=""  # its basename — the fallback display name when there's no slug
SLUG=""       # GitHub "owner/name", or "" when there's no github.com remote
resolve_repo(){
  if ! git rev-parse --is-inside-work-tree >/dev/null 2>&1; then
    printf "\n  ${R}not inside a git repository.${X} ${DIM}vegtam walks into a repo — cd into one and try again.${X}\n\n" >&2
    return 1
  fi
  RROOT="$(git rev-parse --show-toplevel 2>/dev/null)"
  REPO_NAME="$(basename "$RROOT")"
  # Prefer origin; otherwise take the first remote that parses as a github.com URL.
  local url
  url="$(git remote get-url origin 2>/dev/null || true)"
  SLUG="$(github_slug "$url")"
  if [ -z "$SLUG" ]; then
    local r
    for r in $(git remote 2>/dev/null); do
      SLUG="$(github_slug "$(git remote get-url "$r" 2>/dev/null || true)")"
      [ -n "$SLUG" ] && break
    done
  fi
  return 0
}

# Parse "owner/name" out of a git remote URL, but only for github.com hosts.
# Handles the ssh (git@github.com:owner/name.git), https, and ssh:// forms; the
# host match requires a real boundary so lookalikes like "mygithub.com" don't slip
# through. Prints nothing (and succeeds) for anything it can't confidently parse —
# callers treat an empty slug as "no GitHub remote".
github_slug(){
  local u="${1:-}"
  case "$u" in
    *@github.com:*|*@github.com/*|*://github.com/*|github.com:*|github.com/*) ;;
    *) return 0;;
  esac
  local path="${u##*github.com}"   # drop scheme, user, and host — keep the tail
  path="${path#[:/]}"              # drop the leading ':' (ssh) or '/' (https)
  path="${path%/}"                 # drop a trailing slash, then a trailing .git
  path="${path%.git}"
  local owner="${path%%/*}" rest="${path#*/}" name
  name="${rest%%/*}"               # first two path segments are owner/name
  # Require a real "owner/name": both non-empty, and the string actually had a '/'.
  [ -n "$owner" ] && [ -n "$name" ] && [ "$path" != "$owner" ] && printf '%s/%s' "$owner" "$name"
}

# ── status — the flagship one-screen briefing ─────────────────────────────────
cmd_status(){
  is_help "${1:-}" && { help_status; return 0; }
  local fetch=0 json=0 a
  for a in "$@"; do case "$a" in
    -f|--fetch) fetch=1;;
    --json) json=1;;
    -*) printf "  ${Y}ignoring unknown option: %s${X}\n" "$a";;
  esac; done
  [ "$json" = 1 ] && { json_ok || return 1; }
  resolve_repo || return 1

  # Optional fresh-ness pass: update remote-tracking refs so ahead/behind and the
  # default branch reflect the real remote, at the cost of one network round-trip.
  # In --json mode the progress line would corrupt the output, so it goes to stderr.
  [ "$fetch" = 1 ] && { [ "$json" = 0 ] && printf "  ${DIM}fetching…${X}\n" || printf "fetching…\n" >&2; git fetch -q --all 2>/dev/null || true; }

  # ── local git facts (always available, no network) ──
  local branch def sha chg stash last ab ahead behind
  branch="$(git symbolic-ref --short HEAD 2>/dev/null || echo detached)"
  def="$(git symbolic-ref --short refs/remotes/origin/HEAD 2>/dev/null | sed 's#^origin/##')"
  sha="$(git rev-parse --short HEAD 2>/dev/null || echo '-')"
  chg="$(git status --porcelain 2>/dev/null | grep -c . || true)"
  stash="$(git stash list 2>/dev/null | grep -c . || true)"
  last="$(short "$(git log -1 --format=%cr 2>/dev/null || true)")"
  # ahead/behind vs the branch's upstream. left-right counts "behind<TAB>ahead";
  # the whole thing fails (and we note "no upstream") when the branch tracks nothing.
  if ab="$(git rev-list --left-right --count '@{upstream}...HEAD' 2>/dev/null)"; then
    behind="${ab%%[[:space:]]*}"; ahead="${ab##*[[:space:]]}"
  else behind=""; ahead=""; fi

  # ── remote facts (best-effort; each degrades to a note on failure) ──
  local vis="" desc="" isfork="" parent="" defremote="" meta=""
  local have_remote=0
  if [ -n "$SLUG" ] && have gh; then
    # One call for the repo-level metadata. gh's built-in --jq needs no system jq,
    # and `// ""` keeps missing fields (e.g. a null parent) from becoming "null".
    # Fields are joined with the unit separator (\x1f), NOT a tab: `IFS=$'\t' read`
    # collapses adjacent tabs (tab is IFS-whitespace), which would silently drop an
    # empty field — e.g. a blank description — and shift every field left.
    meta="$(gh repo view "$SLUG" \
      --json visibility,description,isFork,parent,defaultBranchRef \
      --jq '[(.visibility|ascii_downcase), (.description // ""), (.isFork|tostring), (.parent.nameWithOwner // ""), (.defaultBranchRef.name // "")] | join("\u001f")' 2>/dev/null || true)"
    if [ -n "$meta" ]; then
      have_remote=1
      IFS=$'\x1f' read -r vis desc isfork parent defremote <<<"$meta"
    fi
  fi
  # Fall back to the remote's default branch when git has no origin/HEAD locally.
  [ -z "$def" ] && def="${defremote:-main}"

  # ── remote-only facts: CI rollup for HEAD, and open PR/issue counts ──
  # Computed once here so the JSON and human renders share them (one set of API calls).
  local ci="" nprs="" nissues=""
  if [ "$have_remote" = 1 ]; then
    [ "$sha" != "-" ] && ci="$(ci_rollup "$(git rev-parse HEAD 2>/dev/null)")"
    nprs="$(gh_count 'type:pr state:open')"
    nissues="$(gh_count 'type:issue state:open')"
  fi

  # ── JSON output — one object, built with jq so escaping is always correct ──
  if [ "$json" = 1 ]; then
    local hasup=false; [ -n "$ahead" ] && hasup=true
    jq -n \
      --arg slug "$SLUG" --arg name "$REPO_NAME" --arg root "$RROOT" \
      --arg desc "$desc" --arg vis "$vis" --arg defbranch "$def" --arg branch "$branch" \
      --arg parent "$parent" --arg sha "$sha" --arg ci "$ci" --arg last "$last" \
      --argjson isFork "${isfork:-false}" \
      --argjson dirty "$(num "$chg")" --argjson stashes "$(num "$stash")" \
      --argjson hasUpstream "$hasup" \
      --argjson ahead "$(num "$ahead")" --argjson behind "$(num "$behind")" \
      --argjson remoteAvailable "$([ "$have_remote" = 1 ] && echo true || echo false)" \
      --argjson openPRs "$(num "$nprs")" --argjson openIssues "$(num "$nissues")" \
      '{
         repo: (if $slug=="" then null else $slug end),
         name: $name, root: $root,
         description: (if $desc=="" then null else $desc end),
         visibility: (if $vis=="" then null else $vis end),
         defaultBranch: $defbranch, branch: $branch, isFork: $isFork,
         parent: (if $parent=="" then null else $parent end),
         dirty: $dirty, stashes: $stashes,
         hasUpstream: $hasUpstream, ahead: $ahead, behind: $behind,
         head: {
           sha: (if $sha=="-" then null else $sha end),
           ci: (if $ci=="" then null else $ci end),
           lastCommitRelative: (if $last=="" then null else $last end)
         },
         openPRs: $openPRs, openIssues: $openIssues,
         remoteAvailable: $remoteAvailable
       }'
    return 0
  fi

  # ── header ──
  printf "\n  ${BD}vegtam${X}  ${DIM}·${X}  ${BD}%s${X}\n" "${SLUG:-$REPO_NAME}"
  [ -n "$desc" ] && printf "  ${DIM}%s${X}\n" "$desc"

  # ── repo-level row: visibility · default branch · fork relationship ──
  # The visibility dot only appears when we actually read the repo from GitHub;
  # otherwise we lead with the default branch and let the note below say why.
  if [ "$have_remote" = 1 ]; then
    local visdot
    case "$vis" in
      public)   visdot="${G}● public${X}";;
      private)  visdot="${Y}● private${X}";;
      internal) visdot="${C}● internal${X}";;
      *)        visdot="${DIM}● ${vis:-unknown}${X}";;
    esac
    printf "\n    %s   ${DIM}·${X}   default ${BD}%s${X}" "$visdot" "$def"
    [ "$isfork" = "true" ] && [ -n "$parent" ] && printf "   ${DIM}·${X}   ${M}fork of %s${X}" "$parent"
  else
    printf "\n    default ${BD}%s${X}" "$def"
  fi
  printf "\n"

  # ── working-tree row: current branch, dirty state, ahead/behind, stashes ──
  local brc
  if [ "$branch" = "$def" ]; then brc="${G}${branch}${X}"; else brc="${C}${BD}${branch}${X}"; fi
  printf "    branch    %s" "$brc"
  if [ "$chg" -eq 0 ]; then printf "  ${G}✓ clean${X}"; else printf "  ${Y}● %s changed${X}" "$chg"; fi
  if [ -n "$ahead" ]; then
    [ "$ahead"  -gt 0 ] && printf "  ${Y}↑%s${X}" "$ahead"
    [ "$behind" -gt 0 ] && printf "  ${Y}↓%s${X}" "$behind"
    [ "$ahead" -eq 0 ] && [ "$behind" -eq 0 ] && printf "  ${DIM}(up to date)${X}"
  else printf "  ${DIM}(no upstream)${X}"; fi
  [ "$stash" -gt 0 ] && printf "  ${M}⚑%s${X}" "$stash"
  printf "\n"

  # ── head row: latest commit, its CI rollup, and how long ago ──
  printf "    head      ${BD}%s${X}" "$sha"
  if [ "$have_remote" = 1 ] && [ "$sha" != "-" ]; then
    case "$ci" in
      pass)    printf "  ${G}✓ checks pass${X}";;
      fail)    printf "  ${R}✗ checks failing${X}";;
      pending) printf "  ${Y}● checks running${X}";;
      *)       printf "  ${DIM}· no checks${X}";;
    esac
  fi
  [ -n "$last" ] && printf "  ${DIM}· %s ago${X}" "$last"
  printf "\n"

  # ── activity row: open PR / issue counts (remote only) ──
  if [ "$have_remote" = 1 ]; then
    printf "    open      ${BD}%s${X} PRs   ${DIM}·${X}   ${BD}%s${X} issues\n" "${nprs:-?}" "${nissues:-?}"
  fi

  # ── degradation notes — say why a section is missing, don't just drop it ──
  printf "\n"
  if [ -z "$SLUG" ]; then
    note "no github.com remote — showing local git only."
  elif ! have gh; then
    note "gh not installed — remote sections (visibility, checks, PRs/issues) are unavailable."
  elif [ "$have_remote" = 0 ]; then
    note "couldn't read $SLUG on GitHub — no access, or the network is down."
  fi
  printf "\n"
}

# Roll up a commit's CI into one word. Combines the check-runs API (GitHub Actions
# & most apps) with the older commit-status API (some CI still posts there), so we
# don't miss a signal from either source, then defers to classify_ci for the verdict.
ci_rollup(){
  local sha="${1:-}"; [ -z "$sha" ] && { echo none; return; }
  local runs states
  runs="$(gh api "repos/$SLUG/commits/$sha/check-runs" --jq '.check_runs[] | (.conclusion // "pending")' 2>/dev/null || true)"
  states="$(gh api "repos/$SLUG/commits/$sha/status"     --jq '.statuses[].state' 2>/dev/null || true)"
  classify_ci "$(printf '%s\n%s' "$runs" "$states")"
}

# Exact open count for the current repo via the search API — one call, and it
# separates PRs from issues (which the repo's open_issues_count conflates).
gh_count(){ gh api -X GET search/issues --jq '.total_count' -f q="repo:$SLUG $1" 2>/dev/null || true; }

# ── branches — local + remote branches, purely descriptive (no pruning here) ──
cmd_branches(){
  is_help "${1:-}" && { help_branches; return 0; }
  local fetch=0 json=0 a
  for a in "$@"; do case "$a" in
    -f|--fetch) fetch=1;;
    --json) json=1;;
    -*) printf "  ${Y}ignoring unknown option: %s${X}\n" "$a";;
  esac; done
  [ "$json" = 1 ] && { json_ok || return 1; }
  resolve_repo || return 1
  [ "$fetch" = 1 ] && { [ "$json" = 0 ] && printf "  ${DIM}fetching…${X}\n" || printf "fetching…\n" >&2; git fetch -q --prune --all 2>/dev/null || true; }

  local def cur defref; def="$(default_branch)"; defref="$(default_ref "$def")"
  cur="$(git symbolic-ref --short HEAD 2>/dev/null || echo detached)"
  # Local branches already merged into the default — one membership set, tested per branch.
  local mergedset; mergedset="$(git for-each-ref --format='%(refname:short)' --merged "$defref" refs/heads 2>/dev/null || true)"

  # ── JSON: local branches + the origin-only ones, as two arrays in one object ──
  if [ "$json" = 1 ]; then
    local -a locals=() remotes=(); local b up track ts merged rb rts
    while IFS=$'\x1f' read -r b up track ts; do
      [ -z "$b" ] && continue
      merged=false; { grep -qx "$b" <<<"$mergedset" && [ "$b" != "$def" ]; } && merged=true
      locals+=("$(jq -n --arg name "$b" --arg up "$up" --arg track "$track" --argjson committed "$(num "$ts")" \
        --argjson merged "$merged" \
        --argjson current "$([ "$b" = "$cur" ] && echo true || echo false)" \
        --argjson isDefault "$([ "$b" = "$def" ] && echo true || echo false)" \
        '{name:$name, upstream:(if $up=="" then null else $up end), track:(if $track=="" then null else $track end), committed:$committed, merged:$merged, current:$current, default:$isDefault}')")
    done < <(git for-each-ref --sort=-committerdate \
               --format=$'%(refname:short)\x1f%(upstream:short)\x1f%(upstream:track)\x1f%(committerdate:unix)' refs/heads 2>/dev/null)
    while IFS=$'\x1f' read -r rb rts; do
      rb="${rb#origin/}"; [ -z "$rb" ] && continue; [ "$rb" = "HEAD" ] && continue
      git show-ref --verify -q "refs/heads/$rb" && continue
      remotes+=("$(jq -n --arg name "$rb" --argjson committed "$(num "$rts")" '{name:$name, committed:$committed}')")
    done < <(git for-each-ref --sort=-committerdate \
               --format=$'%(refname:short)\x1f%(committerdate:unix)' refs/remotes/origin 2>/dev/null)
    local ljson="[]" rjson="[]"
    [ "${#locals[@]}"  -gt 0 ] && ljson="$(printf '%s\n' "${locals[@]}"  | jq -s '.')"
    [ "${#remotes[@]}" -gt 0 ] && rjson="$(printf '%s\n' "${remotes[@]}" | jq -s '.')"
    jq -n --arg defbranch "$def" --argjson local "$ljson" --argjson remoteOnly "$rjson" \
      '{defaultBranch:$defbranch, local:$local, remoteOnly:$remoteOnly}'
    return 0
  fi

  printf "\n  ${BD}vegtam branches${X}  ${DIM}·  %s  ·  default %s${X}\n\n" "${SLUG:-$REPO_NAME}" "$def"

  # ── local branches, newest commit first ──
  # \x1f separators: upstream:short and upstream:track are routinely empty, and a
  # tab IFS would collapse the empties and misalign every field after them.
  local n_local=0 n_merged=0 b up track ts
  while IFS=$'\x1f' read -r b up track ts; do
    [ -z "$b" ] && continue
    n_local=$((n_local+1))
    # "merged" flags a feature branch fully folded into the default — a tidy candidate.
    # The default branch is trivially merged into itself, so it's never tagged or counted.
    local merged=0
    if grep -qx "$b" <<<"$mergedset" && [ "$b" != "$def" ]; then merged=1; n_merged=$((n_merged+1)); fi
    # Pad the plain name first, THEN colorize — color escapes would throw off %-Ns width.
    local pad; pad="$(printf '%-26s' "$b")"
    local marker="  " bc="$pad"
    if   [ "$b" = "$cur" ]; then marker="${C}▸${X} "; bc="${C}${BD}${pad}${X}"
    elif [ "$b" = "$def" ]; then bc="${G}${pad}${X}"; fi
    # tracking + merge state
    local st=""
    if   [ -z "$up" ];      then st="${DIM}local-only${X}"
    elif [ -n "$track" ];   then st="${Y}${track}${X}"        # e.g. [ahead 2, behind 1] or [gone]
    else                         st="${DIM}up to date${X}"; fi
    [ "$merged" = 1 ] && st="$st  ${G}merged${X}"
    printf "  %s%s  %s  ${DIM}· %s${X}\n" "$marker" "$bc" "$st" "$(age_short "${ts:-0}")"
  done < <(git for-each-ref --sort=-committerdate \
             --format=$'%(refname:short)\x1f%(upstream:short)\x1f%(upstream:track)\x1f%(committerdate:unix)' \
             refs/heads 2>/dev/null)

  # ── remote branches with no local counterpart — what's on origin you don't have ──
  local -a remote_only=(); local rb rts
  while IFS=$'\x1f' read -r rb rts; do
    rb="${rb#origin/}"; [ -z "$rb" ] && continue; [ "$rb" = "HEAD" ] && continue
    git show-ref --verify -q "refs/heads/$rb" && continue      # already have it locally
    remote_only+=("$rb"$'\x1f'"$rts")
  done < <(git for-each-ref --sort=-committerdate \
             --format=$'%(refname:short)\x1f%(committerdate:unix)' refs/remotes/origin 2>/dev/null)

  if [ "${#remote_only[@]}" -gt 0 ]; then
    printf "\n  ${DIM}on origin, not local${X}\n"
    local shown=0 e rname rt
    for e in "${remote_only[@]}"; do
      [ "$shown" -ge 12 ] && break
      IFS=$'\x1f' read -r rname rt <<<"$e"
      printf "    ${DIM}∙${X} %-26s  ${DIM}· %s${X}\n" "$rname" "$(age_short "${rt:-0}")"
      shown=$((shown+1))
    done
    [ "${#remote_only[@]}" -gt 12 ] && note "… and $(( ${#remote_only[@]} - 12 )) more on origin."
  fi

  printf "\n  ${BD}%d local${X} ${DIM}·${X} ${G}%d merged${X} ${DIM}·${X} ${DIM}%d remote-only${X}\n\n" \
    "$n_local" "$n_merged" "${#remote_only[@]}"
}

# ── prs — open pull requests with their check status; highlight your own ──────
cmd_prs(){
  is_help "${1:-}" && { help_prs; return 0; }
  local json=0 a
  for a in "$@"; do case "$a" in
    --json) json=1;;
    -*) printf "  ${Y}ignoring unknown option: %s${X}\n" "$a";;
  esac; done
  [ "$json" = 1 ] && { json_ok || return 1; }
  resolve_repo || return 1
  # In --json mode a hard guard emits an empty array (reason to stderr) so a consumer
  # always gets valid JSON; the human view prints an inline note instead.
  if [ -z "$SLUG" ]; then
    [ "$json" = 1 ] && { printf '[]\n'; printf "no github.com remote — prs needs a GitHub repo.\n" >&2; return 0; }
    printf "\n  ${BD}vegtam prs${X}  ${DIM}·  %s  ·  open pull requests${X}\n\n" "$REPO_NAME"
    note "no github.com remote — prs needs a GitHub repo."; printf "\n"; return 0
  fi
  if ! have gh; then
    [ "$json" = 1 ] && { printf '[]\n'; printf "gh not installed — prs needs the GitHub CLI.\n" >&2; return 0; }
    printf "\n  ${BD}vegtam prs${X}  ${DIM}·  %s  ·  open pull requests${X}\n\n" "$SLUG"
    note "gh not installed — prs needs the GitHub CLI."; printf "\n"; return 0
  fi
  [ "$json" = 0 ] && printf "\n  ${BD}vegtam prs${X}  ${DIM}·  %s  ·  open pull requests${X}\n\n" "$SLUG"

  # One list call. statusCheckRollup rides along so we show each PR's CI without a
  # per-PR round-trip; its elements are check-runs (conclusion/status) or legacy
  # status contexts (state), so we coalesce whichever field is present.
  local rows
  rows="$(gh pr list -R "$SLUG" --state open --limit 50 \
    --json number,title,author,headRefName,isDraft,createdAt,statusCheckRollup \
    --jq '.[] | [ (.number|tostring), .title, (.author.login // "?"), .headRefName, (.isDraft|tostring), .createdAt, ([.statusCheckRollup[]? | (.conclusion // .state // .status // "")] | join(",")) ] | join("\u001f")' 2>/dev/null || true)"

  local mylogin; mylogin="$(gh_login)"

  # ── JSON: one object per PR, carrying the same computed CI verdict the view shows ──
  if [ "$json" = 1 ]; then
    local -a objs=(); local num title author branch draft created ciraw
    while IFS=$'\x1f' read -r num title author branch draft created ciraw; do
      [ -z "$num" ] && continue
      local ismine=false; [ -n "$mylogin" ] && [ "$author" = "$mylogin" ] && ismine=true
      objs+=("$(jq -n --argjson number "$(num "$num")" --arg title "$title" --arg author "$author" \
        --arg branch "$branch" --argjson draft "${draft:-false}" --arg created "$created" \
        --arg checks "$(classify_ci "$ciraw")" --argjson mine "$ismine" \
        '{number:$number, title:$title, author:$author, branch:$branch, draft:$draft, createdAt:$created, checks:$checks, mine:$mine}')")
    done <<< "$rows"
    if [ "${#objs[@]}" -eq 0 ]; then printf '[]\n'; else printf '%s\n' "${objs[@]}" | jq -s '.'; fi
    return 0
  fi

  if [ -z "$rows" ]; then
    # Tell "genuinely no open PRs" apart from "couldn't read the repo".
    if gh repo view "$SLUG" >/dev/null 2>&1; then printf "  ${G}✓ no open pull requests${X}\n\n"
    else note "couldn't read $SLUG on GitHub — no access, or the network is down."; printf "\n"; fi
    return 0
  fi

  local n=0 mine=0 num title author branch draft created ciraw
  while IFS=$'\x1f' read -r num title author branch draft created ciraw; do
    [ -z "$num" ] && continue
    n=$((n+1))
    local ci cistr; ci="$(classify_ci "$ciraw")"
    case "$ci" in
      pass) cistr="${G}✓${X}";; fail) cistr="${R}✗${X}";; pending) cistr="${Y}●${X}";; *) cistr="${DIM}·${X}";;
    esac
    local you="" dtag=""
    [ -n "$mylogin" ] && [ "$author" = "$mylogin" ] && { you="  ${C}(you)${X}"; mine=$((mine+1)); }
    [ "$draft" = "true" ] && dtag="  ${DIM}[draft]${X}"
    local age; age="$(age_short "$(date -d "$created" +%s 2>/dev/null || date +%s)")"
    printf "  %s ${BD}#%-4s${X} %s%s%s\n" "$cistr" "$num" "$title" "$dtag" "$you"
    printf "       ${DIM}%s ← @%s · %s ago${X}\n" "$branch" "$author" "$age"
  done <<< "$rows"

  printf "\n  ${BD}%d open${X}%s\n\n" "$n" "$([ "$mine" -gt 0 ] && printf " ${DIM}·${X} ${C}%d yours${X}" "$mine")"
}

# ── log — a timeline of what changed: commits, merged PRs, releases ───────────
cmd_log(){
  is_help "${1:-}" && { help_log; return 0; }
  local since="2w" json=0
  while [ $# -gt 0 ]; do case "$1" in
    --since) shift; since="${1:-2w}";;
    --json) json=1;;
    -*) printf "  ${Y}ignoring unknown option: %s${X}\n" "$1";;
  esac; shift; done
  [ "$json" = 1 ] && { json_ok || return 1; }
  resolve_repo || return 1

  local sincegit; sincegit="$(since_to_gitdate "$since")" \
    || { printf "\n  ${R}invalid --since window:${X} %s ${DIM}(expected e.g. 6h, 3d, 2w, 1mo)${X}\n\n" "$since"; return 1; }
  local since_epoch since_iso
  since_epoch="$(date -d "$sincegit" +%s 2>/dev/null || echo 0)"
  since_iso="$(date -d "$sincegit" +%Y-%m-%d 2>/dev/null || true)"

  # Accumulate events in memory (no temp files, no stored state): each is
  # "epoch \x1f type \x1f fieldA \x1f fieldB", sorted newest-first at the end.
  local -a EV=()
  local at h msg

  # commits on the current branch (local, fast) — merges are skipped, since a
  # merged PR shows up as its own event below.
  while IFS=$'\x1f' read -r at h msg; do
    [ -z "$at" ] && continue
    EV+=("$at"$'\x1f'"commit"$'\x1f'"$h"$'\x1f'"$msg")
  done < <(git log --no-merges --since="$sincegit" --format=$'%at\x1f%h\x1f%s' HEAD 2>/dev/null)

  # merged PRs + releases within the window (network, best-effort)
  if [ -n "$SLUG" ] && have gh; then
    local num title mergedAt tag rname pub
    while IFS=$'\x1f' read -r num title mergedAt; do
      [ -z "$num" ] && continue
      at="$(date -d "$mergedAt" +%s 2>/dev/null)" || continue
      EV+=("$at"$'\x1f'"pr"$'\x1f'"$num"$'\x1f'"$title")
    done < <(gh pr list -R "$SLUG" --state merged --limit 50 --search "merged:>=$since_iso" \
              --json number,title,mergedAt \
              --jq '.[] | [(.number|tostring), .title, .mergedAt] | join("\u001f")' 2>/dev/null)
    while IFS=$'\x1f' read -r tag rname pub; do
      [ -z "$tag" ] && continue
      at="$(date -d "$pub" +%s 2>/dev/null)" || continue
      [ "$at" -lt "$since_epoch" ] && continue
      # A release name often just repeats the tag ("v1.2.0" or "v1.2.0 — subtitle").
      # Keep only the part after the tag so the line reads "⚑ v1.2.0 subtitle", not
      # "⚑ v1.2.0 v1.2.0 — subtitle".
      local sub=""
      if [ -n "$rname" ] && [ "$rname" != "$tag" ]; then
        if [ "${rname#"$tag"}" != "$rname" ]; then
          sub="$(sed -E 's/^[[:space:]]*[—:._-]+[[:space:]]*//' <<<"${rname#"$tag"}")"
        else sub="$rname"; fi
      fi
      EV+=("$at"$'\x1f'"release"$'\x1f'"$tag"$'\x1f'"$sub")
    done < <(gh release list -R "$SLUG" --limit 20 --json tagName,name,publishedAt \
              --jq '.[] | [.tagName, (.name // ""), .publishedAt] | join("\u001f")' 2>/dev/null)
  fi

  # ── JSON: the whole timeline as an array of typed events, newest first ──
  if [ "$json" = 1 ]; then
    if [ "${#EV[@]}" -eq 0 ]; then printf '[]\n'; return 0; fi
    local -a objs=(); local type fa fb
    while IFS=$'\x1f' read -r at type fa fb; do
      [ -z "$at" ] && continue
      case "$type" in
        commit)  objs+=("$(jq -n --argjson ts "$(num "$at")" --arg sha "$fa" --arg title "$fb" '{type:"commit", ts:$ts, sha:$sha, title:$title}')");;
        pr)      objs+=("$(jq -n --argjson ts "$(num "$at")" --argjson number "$(num "$fa")" --arg title "$fb" '{type:"pr", ts:$ts, number:$number, title:$title}')");;
        release) objs+=("$(jq -n --argjson ts "$(num "$at")" --arg tag "$fa" --arg name "$fb" '{type:"release", ts:$ts, tag:$tag, name:(if $name=="" then null else $name end)}')");;
      esac
    done < <(printf '%s\n' "${EV[@]}" | sort -t $'\x1f' -k1,1nr)
    if [ "${#objs[@]}" -eq 0 ]; then printf '[]\n'; else printf '%s\n' "${objs[@]}" | jq -s '.'; fi
    return 0
  fi

  printf "\n  ${BD}vegtam log${X}  ${DIM}·  %s  ·  since %s${X}\n\n" "${SLUG:-$REPO_NAME}" "$since"
  if [ "${#EV[@]}" -eq 0 ]; then note "nothing in the last $since."; printf "\n"; return 0; fi

  local total="${#EV[@]}" CAP=50 n=0 type fa fb
  while IFS=$'\x1f' read -r at type fa fb; do
    [ "$n" -ge "$CAP" ] && break
    case "$type" in
      pr)      printf "  ${DIM}%-4s${X}  ${C}⑃${X} ${BD}#%s${X} %s ${DIM}(merged)${X}\n" "$(age_short "$at")" "$fa" "$fb";;
      release) printf "  ${DIM}%-4s${X}  ${M}⚑${X} ${BD}%s${X} %s\n"                    "$(age_short "$at")" "$fa" "$fb";;
      commit)  printf "  ${DIM}%-4s${X}  ${DIM}● %s${X} %s\n"                            "$(age_short "$at")" "$fa" "$fb";;
    esac
    n=$((n+1))
  done < <(printf '%s\n' "${EV[@]}" | sort -t $'\x1f' -k1,1nr)

  [ "$total" -gt "$CAP" ] && note "… and $((total-CAP)) more — narrow the window with --since."
  printf "\n  ${BD}%d events${X} ${DIM}since %s${X}\n\n" "$total" "$since"
}

# health --json — the same three signals as the human view, as one structured
# object. Nullable fields (alerts you can't read) come through as JSON null so a
# consumer can tell "no access" from "zero found". $1 = the repo owner (or "").
health_json(){
  local owner="${1:-}"

  # ── alerts ── available:false when we can't read them; open/bySeverity/items null then
  local alerts_available=false alerts_rows="" open_json=null bysev_json=null items_json=null
  if [ -n "$SLUG" ] && have gh; then
    local _ok=1
    alerts_rows="$(gh api "repos/$SLUG/dependabot/alerts?state=open&per_page=100" \
      --jq 'def rank: {"critical":0,"high":1,"medium":2,"low":3}[.] // 4;
            [.[] | {r:(.security_advisory.severity|rank), sev:.security_advisory.severity, num:.number,
                    pkg:.dependency.package.name, sum:.security_advisory.summary}]
            | sort_by(.r) | .[] | [.sev,(.num|tostring),.pkg,.sum] | join("\u001f")' 2>/dev/null)" || _ok=0
    if [ "$_ok" = 1 ]; then
      alerts_available=true
      local sevs; sevs="$(cut -d $'\x1f' -f1 <<<"$alerts_rows")"
      open_json="$([ -n "$alerts_rows" ] && grep -c . <<<"$alerts_rows" || echo 0)"
      bysev_json="$(jq -n \
        --argjson c "$(grep -c '^critical$' <<<"$sevs" || true)" --argjson h "$(grep -c '^high$' <<<"$sevs" || true)" \
        --argjson m "$(grep -c '^medium$' <<<"$sevs" || true)"   --argjson l "$(grep -c '^low$' <<<"$sevs" || true)" \
        '{critical:$c,high:$h,medium:$m,low:$l}')"
      local -a ai=(); local sev num pkg sum
      while IFS=$'\x1f' read -r sev num pkg sum; do [ -z "$sev" ] && continue
        ai+=("$(jq -n --arg s "$sev" --argjson n "$(num "$num")" --arg p "$pkg" --arg u "$sum" \
          '{severity:$s,number:$n,package:$p,summary:$u}')")
      done <<<"$alerts_rows"
      items_json="$([ "${#ai[@]}" -gt 0 ] && printf '%s\n' "${ai[@]}" | jq -s '.' || echo '[]')"
    fi
  fi

  # ── deps ──
  local have_dependabot=false
  { [ -f "$RROOT/.github/dependabot.yml" ] || [ -f "$RROOT/.github/dependabot.yaml" ]; } && have_dependabot=true
  local manifests eco_json="[]"
  manifests="$(find "$RROOT" -maxdepth 2 \
    \( -type d \( -name node_modules -o -name vendor -o -name dist -o -name build -o -name .git \) -prune \) \
    -o "${MANIFEST_FIND_EXPR[@]}" -print 2>/dev/null || true)"
  [ -n "$manifests" ] && eco_json="$(xargs -n1 basename <<<"$manifests" | while read -r f; do manifest_ecosystem "$f"; done | sort -u | jq -R . | jq -s '.')"
  local unmonitored=false; [ -n "$manifests" ] && [ "$have_dependabot" = false ] && unmonitored=true
  local dpr_rows="" dpr_ok=true updpr_json="[]"
  if [ -n "$SLUG" ] && have gh; then
    dpr_rows="$(gh pr list -R "$SLUG" --state open --author "app/dependabot" --limit 50 \
      --json number,title,createdAt --jq '.[] | [(.number|tostring), .title, .createdAt] | join("\u001f")' 2>/dev/null)" || dpr_ok=false
  else dpr_ok=false; fi
  if [ -n "$dpr_rows" ]; then
    local -a dp=(); local dnum dtitle dcreated
    while IFS=$'\x1f' read -r dnum dtitle dcreated; do [ -z "$dnum" ] && continue
      dp+=("$(jq -n --argjson n "$(num "$dnum")" --arg t "$dtitle" --arg c "$dcreated" '{number:$n,title:$t,createdAt:$c}')")
    done <<<"$dpr_rows"
    updpr_json="$([ "${#dp[@]}" -gt 0 ] && printf '%s\n' "${dp[@]}" | jq -s '.' || echo '[]')"
  fi

  # ── actions ── (mirrors the human scan: third-party uses: not pinned to a SHA)
  local workflows=false; [ -d "$RROOT/.github/workflows" ] && workflows=true
  local -a UNPINNED=(); local wf line
  while read -r wf; do
    [ -z "$wf" ] && continue
    local wfname; wfname="$(basename "$wf")"
    while IFS= read -r line; do
      [[ "$line" =~ ^[[:space:]]*-?[[:space:]]*uses:[[:space:]]*([A-Za-z0-9_.-]+/[A-Za-z0-9_.-]+)@([A-Za-z0-9_./-]+) ]] || continue
      local action="${BASH_REMATCH[1]}" ref="${BASH_REMATCH[2]}"
      [ -n "$owner" ] && [[ "$action" == "$owner/"* ]] && continue
      [[ "$ref" =~ ^[0-9a-f]{40}$ ]] && continue
      UNPINNED+=("$action"$'\x1f'"$ref"$'\x1f'"$wfname")
    done < "$wf"
  done < <(find "$RROOT/.github/workflows" -maxdepth 1 -type f \( -name '*.yml' -o -name '*.yaml' \) 2>/dev/null)
  local unpinned_json="[]"
  if [ "${#UNPINNED[@]}" -gt 0 ]; then
    declare -A LATEST=(); local act
    if have gh; then
      while read -r act; do [ -z "$act" ] && continue
        LATEST[$act]="$(gh api "repos/$act/releases/latest" --jq '.tag_name' 2>/dev/null || true)"
      done < <(printf '%s\n' "${UNPINNED[@]}" | cut -d $'\x1f' -f1 | sort -u)
    fi
    local -a up=(); local u action ref wfn
    for u in "${UNPINNED[@]}"; do
      IFS=$'\x1f' read -r action ref wfn <<<"$u"
      local latest="${LATEST[$action]:-}" outdated=false rmaj lmaj
      rmaj="$(majnum "$ref")"; lmaj="$(majnum "$latest")"
      [ -n "$rmaj" ] && [ -n "$lmaj" ] && [ "$lmaj" -gt "$rmaj" ] && outdated=true
      up+=("$(jq -n --arg a "$action" --arg r "$ref" --arg w "$wfn" --arg l "$latest" --argjson o "$outdated" \
        '{action:$a,ref:$r,workflow:$w,latest:(if $l=="" then null else $l end),outdated:$o}')")
    done
    unpinned_json="$(printf '%s\n' "${up[@]}" | jq -s '.')"
  fi

  # signals — identical accounting to the human footer
  local n_alerts=0; [ "$open_json" != null ] && n_alerts="$open_json"
  local n_dpr=0; [ -n "$dpr_rows" ] && n_dpr="$(grep -c . <<<"$dpr_rows")"
  local n_unmon=0; [ "$unmonitored" = true ] && n_unmon=1
  local signals=$(( n_alerts + n_unmon + n_dpr + ${#UNPINNED[@]} ))

  jq -n \
    --argjson available "$alerts_available" --argjson open "$open_json" \
    --argjson bysev "$bysev_json" --argjson items "$items_json" \
    --argjson dependabot "$have_dependabot" --argjson ecosystems "$eco_json" \
    --argjson unmonitored "$unmonitored" --argjson updchecked "$dpr_ok" --argjson updprs "$updpr_json" \
    --argjson workflows "$workflows" --argjson unpinned "$unpinned_json" --argjson signals "$signals" \
    '{
       alerts: { available:$available, open:$open, bySeverity:$bysev, items:$items },
       deps:   { dependabotConfigured:$dependabot, ecosystems:$ecosystems, unmonitored:$unmonitored, updatePRsChecked:$updchecked, updatePRs:$updprs },
       actions:{ workflows:$workflows, unpinned:$unpinned },
       signals: $signals
     }'
}

# ── health — security & freshness, best-effort and access-aware ───────────────
# Three neutral, widely-recommended signals: open Dependabot alerts, dependency
# freshness, and unpinned third-party actions. Every remote piece degrades to a
# note when gh is absent, the remote isn't GitHub, or you lack the access it needs
# (alerts in particular require security read, which a contributor usually lacks).
cmd_health(){
  is_help "${1:-}" && { help_health; return 0; }
  local json=0 a
  for a in "$@"; do case "$a" in
    --json) json=1;;
    -*) printf "  ${Y}ignoring unknown option: %s${X}\n" "$a";;
  esac; done
  [ "$json" = 1 ] && { json_ok || return 1; }
  resolve_repo || return 1
  local owner=""; [ -n "$SLUG" ] && owner="${SLUG%%/*}"
  # Machine-readable output takes a separate emitter so the (validated) human
  # renderer below stays untouched. Both draw the same three signals the same way.
  [ "$json" = 1 ] && { health_json "$owner"; return $?; }
  local signals=0

  printf "\n  ${BD}vegtam health${X}  ${DIM}·  %s  ·  security & freshness${X}\n\n" "${SLUG:-$REPO_NAME}"

  # ── 1. Dependabot alerts ──
  # gh api exits non-zero on an HTTP error (no access / not enabled), which we use
  # to tell "can't see alerts" apart from "saw them, there are none". No jq needed.
  printf "  ${BD}alerts${X}  ${DIM}open Dependabot security advisories${X}\n"
  if   [ -z "$SLUG" ]; then note "no github.com remote — alerts unavailable."
  elif ! have gh;      then note "gh not installed — alerts unavailable."
  else
    local alerts ok=1
    alerts="$(gh api "repos/$SLUG/dependabot/alerts?state=open&per_page=100" \
      --jq 'def rank: {"critical":0,"high":1,"medium":2,"low":3}[.] // 4;
            [.[] | {r:(.security_advisory.severity|rank), sev:.security_advisory.severity, num:.number,
                    pkg:.dependency.package.name, sum:.security_advisory.summary}]
            | sort_by(.r) | .[] | [.sev,(.num|tostring),.pkg,.sum] | join("\u001f")' 2>/dev/null)" || ok=0
    if [ "$ok" = 0 ]; then
      note "not available — needs security access, or Dependabot alerts aren't enabled here."
    elif [ -z "$alerts" ]; then
      printf "    ${G}✓ no open alerts${X}\n"
    else
      local n; n="$(grep -c . <<<"$alerts")"; signals=$((signals+n))
      local sevs; sevs="$(cut -d $'\x1f' -f1 <<<"$alerts")"
      local c_crit c_high c_med c_low
      c_crit="$(grep -c '^critical$' <<<"$sevs" || true)"; c_high="$(grep -c '^high$' <<<"$sevs" || true)"
      c_med="$(grep -c '^medium$' <<<"$sevs" || true)";   c_low="$(grep -c '^low$' <<<"$sevs" || true)"
      printf "    ${BD}%d open${X}" "$n"
      [ "$c_crit" -gt 0 ] && printf "  ${BD}${R}%d critical${X}" "$c_crit"
      [ "$c_high" -gt 0 ] && printf "  ${R}%d high${X}"          "$c_high"
      [ "$c_med"  -gt 0 ] && printf "  ${Y}%d medium${X}"        "$c_med"
      [ "$c_low"  -gt 0 ] && printf "  ${DIM}%d low${X}"         "$c_low"
      printf "\n"
      local sev num pkg sum shown=0
      while IFS=$'\x1f' read -r sev num pkg sum; do
        [ -z "$sev" ] && continue; [ "$shown" -ge 8 ] && break
        printf "    %s%-8s${X} ${DIM}#%s${X} %-16s %s\n" "$(sev_color "$sev")" "$sev" "$num" "$pkg" "$sum"
        shown=$((shown+1))
      done <<<"$alerts"
      [ "$n" -gt 8 ] && note "… and $((n-8)) more."
    fi
  fi

  # ── 2. dependency freshness ──
  printf "\n  ${BD}deps${X}  ${DIM}dependency freshness${X}\n"
  local have_dependabot=0
  { [ -f "$RROOT/.github/dependabot.yml" ] || [ -f "$RROOT/.github/dependabot.yaml" ]; } && have_dependabot=1
  # Manifests near the root — pruning the usual vendored/build dirs so we don't
  # descend into a checked-in node_modules and report the world.
  local manifests ecos=""
  manifests="$(find "$RROOT" -maxdepth 2 \
    \( -type d \( -name node_modules -o -name vendor -o -name dist -o -name build -o -name .git \) -prune \) \
    -o "${MANIFEST_FIND_EXPR[@]}" -print 2>/dev/null || true)"
  [ -n "$manifests" ] && ecos="$(xargs -n1 basename <<<"$manifests" | while read -r f; do manifest_ecosystem "$f"; done | sort -u | paste -sd, -)"
  # Open Dependabot version-update PRs (network, if readable).
  local dpr="" dpr_ok=1
  if [ -n "$SLUG" ] && have gh; then
    dpr="$(gh pr list -R "$SLUG" --state open --author "app/dependabot" --limit 50 \
      --json number,title,createdAt --jq '.[] | [(.number|tostring), .title, .createdAt] | join("\u001f")' 2>/dev/null)" || dpr_ok=0
  else dpr_ok=0; fi
  local printed_dep=0
  if [ -n "$ecos" ] && [ "$have_dependabot" = 0 ]; then
    printf "    ${Y}∙${X} manifests present, nothing watching them for updates ${DIM}(%s)${X}\n" "$ecos"
    signals=$((signals+1)); printed_dep=1
  fi
  if [ -n "$dpr" ]; then
    local num title created
    while IFS=$'\x1f' read -r num title created; do
      [ -z "$num" ] && continue
      printf "    ${C}⑃${X} ${BD}#%s${X} %s  ${DIM}· %s ago${X}\n" "$num" "$title" "$(age_short "$(date -d "$created" +%s 2>/dev/null || date +%s)")"
      signals=$((signals+1)); printed_dep=1
    done <<<"$dpr"
  fi
  if [ "$printed_dep" = 0 ]; then
    if   [ "$have_dependabot" = 1 ]; then printf "    ${G}✓ Dependabot configured, no update PRs open${X}\n"
    elif [ -z "$manifests" ];        then printf "    ${DIM}· no dependency manifests found near the root${X}\n"
    else                                  printf "    ${G}✓ nothing pending${X}\n"; fi
    [ "$dpr_ok" = 0 ] && note "update PRs not checked (no gh or no GitHub remote) — local manifest scan only."
  fi

  # ── 3. unpinned third-party actions ──
  printf "\n  ${BD}actions${X}  ${DIM}third-party Actions not pinned to a commit SHA${X}\n"
  local -a UNPINNED=(); local wf line
  while read -r wf; do
    [ -z "$wf" ] && continue
    local wfname; wfname="$(basename "$wf")"
    while IFS= read -r line; do
      [[ "$line" =~ ^[[:space:]]*-?[[:space:]]*uses:[[:space:]]*([A-Za-z0-9_.-]+/[A-Za-z0-9_.-]+)@([A-Za-z0-9_./-]+) ]] || continue
      local action="${BASH_REMATCH[1]}" ref="${BASH_REMATCH[2]}"
      [ -n "$owner" ] && [[ "$action" == "$owner/"* ]] && continue   # skip the repo's own (first-party) actions
      [[ "$ref" =~ ^[0-9a-f]{40}$ ]] && continue                     # already SHA-pinned
      UNPINNED+=("$action"$'\x1f'"$ref"$'\x1f'"$wfname")
    done < "$wf"
  done < <(find "$RROOT/.github/workflows" -maxdepth 1 -type f \( -name '*.yml' -o -name '*.yaml' \) 2>/dev/null)

  if   [ ! -d "$RROOT/.github/workflows" ]; then printf "    ${DIM}· no GitHub Actions workflows${X}\n"
  elif [ "${#UNPINNED[@]}" -eq 0 ];        then printf "    ${G}✓ all third-party actions are SHA-pinned${X}\n"
  else
    # One release lookup per unique action (network) to say outdated vs current.
    declare -A LATEST=(); local act
    if have gh; then
      while read -r act; do [ -z "$act" ] && continue
        LATEST[$act]="$(gh api "repos/$act/releases/latest" --jq '.tag_name' 2>/dev/null || true)"
      done < <(printf '%s\n' "${UNPINNED[@]}" | cut -d $'\x1f' -f1 | sort -u)
    fi
    local u action ref wfn
    for u in "${UNPINNED[@]}"; do
      IFS=$'\x1f' read -r action ref wfn <<<"$u"
      local latest="${LATEST[$action]:-}" info=""
      if [ -n "$latest" ]; then
        local rmaj lmaj; rmaj="$(majnum "$ref")"; lmaj="$(majnum "$latest")"
        if [ -n "$rmaj" ] && [ -n "$lmaj" ] && [ "$lmaj" -gt "$rmaj" ]; then info="${Y}outdated → ${latest}${X}"
        else info="${DIM}latest ${latest}${X}"; fi
      fi
      printf "    ${Y}∙${X} %-38s ${DIM}%-22s${X} %s\n" "$action@$ref" "$wfn" "$info"
    done
    signals=$((signals + ${#UNPINNED[@]}))
  fi

  # ── footer ──
  if [ "$signals" -eq 0 ]; then printf "\n  ${G}✓ clean — nothing flagged${X}\n\n"
  else printf "\n  ${BD}%d signal%s${X} ${DIM}to look at across alerts · deps · actions${X}\n\n" "$signals" "$(plural "$signals")"; fi
}

# ── safe actions ──────────────────────────────────────────────────────────────
# The only commands that change anything. All four are local- and self-scoped:
# they help you work *in* this repo, never "clean up" someone else's. Nothing here
# deletes remote branches, closes others' PRs, or rewrites history. tidy is the one
# with teeth, so it borrows freki's spine: dry-run by default, --apply to act.

# Ask once, reading /dev/tty directly so a piped/redirected stdin can't silently
# auto-confirm a destructive batch. Returns 0 to proceed, 1 to abort.
# Probe that /dev/tty can actually be OPENED, not just that it exists+is readable:
# in some sandboxes the node is present (so `[ -r /dev/tty ]` passes) yet opening it
# fails, so we test the real redirection and treat any failure as "no terminal".
confirm(){
  local reply=""
  if ! { : < /dev/tty; } 2>/dev/null; then
    printf "  ${Y}no usable terminal for confirmation — pass --yes to proceed non-interactively.${X}\n" >&2
    return 1
  fi
  printf "  ${Y}%s${X} ${DIM}[y/N]${X} " "$1" > /dev/tty 2>/dev/null
  read -r reply < /dev/tty 2>/dev/null || reply=""
  case "$reply" in y|Y|yes|YES) return 0;; *) return 1;; esac
}

# ── sync — fast-forward the current branch to its upstream, and nothing more ──
cmd_sync(){
  is_help "${1:-}" && { help_sync; return 0; }
  resolve_repo || return 1
  local branch; branch="$(git symbolic-ref --short HEAD 2>/dev/null || echo detached)"
  printf "\n  ${BD}vegtam sync${X}  ${DIM}·  %s  ·  %s${X}\n\n" "${SLUG:-$REPO_NAME}" "$branch"
  [ "$branch" = detached ] && { note "detached HEAD — check out a branch before syncing."; printf "\n"; return 1; }

  # Everything keys off the branch's configured upstream; no upstream, nothing to do.
  local up; up="$(git rev-parse --abbrev-ref --symbolic-full-name '@{upstream}' 2>/dev/null || true)"
  if [ -z "$up" ]; then
    note "'$branch' has no upstream — nothing to fast-forward against."
    note "set one with:  git branch --set-upstream-to=origin/$branch"
    printf "\n"; return 0
  fi
  local remote="${up%%/*}"

  printf "  ${DIM}fetching %s…${X}\n" "$remote"
  git fetch -q "$remote" 2>/dev/null || { note "couldn't fetch $remote — offline, or no access."; printf "\n"; return 1; }

  # ahead/behind vs the freshly-updated upstream. behind=commits to pull, ahead=your own.
  local ab ahead=0 behind=0
  if ab="$(git rev-list --left-right --count '@{upstream}...HEAD' 2>/dev/null)"; then
    behind="${ab%%[[:space:]]*}"; ahead="${ab##*[[:space:]]}"
  fi

  if [ "$behind" -eq 0 ]; then
    printf "  ${G}✓ already up to date${X} ${DIM}with %s${X}" "$up"
    [ "$ahead" -gt 0 ] && printf " ${DIM}(you're %s ahead)${X}" "$ahead"
    printf "\n\n"; return 0
  fi
  if [ "$ahead" -gt 0 ]; then
    # Diverged: a fast-forward is impossible and reconciling means rebase/merge,
    # which rewrites or merges history — out of scope for a "safe" sync.
    printf "  ${Y}diverged${X} ${DIM}— %s ahead, %s behind %s${X}\n" "$ahead" "$behind" "$up"
    note "sync only fast-forwards; reconcile yourself (git rebase/merge) to keep your $ahead commit(s)."
    printf "\n"; return 0
  fi

  # behind-only → a clean fast-forward. git's own --ff-only refuses to overwrite
  # uncommitted changes, so a dirty tree can't be clobbered; we just flag it.
  [ -n "$(git status --porcelain 2>/dev/null)" ] && note "working tree is dirty — git will refuse the fast-forward if it would overwrite your changes."
  if git merge --ff-only -q '@{upstream}' 2>/dev/null; then
    printf "  ${G}✓ fast-forwarded${X} %s ${DIM}·${X} ${BD}+%s${X} ${DIM}commit%s → %s${X}\n\n" "$branch" "$behind" "$(plural "$behind")" "$(git rev-parse --short HEAD)"
  else
    printf "  ${R}✗ couldn't fast-forward${X} ${DIM}— local changes are in the way. Commit or stash, then retry.${X}\n\n"; return 1
  fi
}

# ── tidy — delete local branches already merged into the default (dry-run first) ──
cmd_tidy(){
  is_help "${1:-}" && { help_tidy; return 0; }
  local APPLY=0 YES=0 a
  for a in "$@"; do case "$a" in
    --apply) APPLY=1;; --yes|-y) YES=1;;
    -*) printf "  ${Y}ignoring unknown option: %s${X}\n" "$a";;
  esac; done
  resolve_repo || return 1

  local def cur defref; def="$(default_branch)"; defref="$(default_ref "$def")"
  cur="$(git symbolic-ref --short HEAD 2>/dev/null || echo detached)"

  printf "\n  ${BD}vegtam tidy${X}  ${DIM}·  %s  ·  merged local branches · %s${X}\n\n" \
    "${SLUG:-$REPO_NAME}" "$([ "$APPLY" = 1 ] && echo 'APPLY' || echo 'dry-run')"

  # Refuse to guess when there's no real default branch to measure "merged" against —
  # falling back to HEAD could mark branches merged into a feature branch as deletable.
  if [ "$defref" = "HEAD" ]; then
    note "couldn't resolve a default branch (no origin/$def or local $def) — refusing to guess what's merged."
    printf "\n"; return 0
  fi

  # Candidates: local branches fully merged into the default, never the default
  # branch itself and never the one you're standing on.
  local -a CAND=(); local b
  while read -r b; do
    [ -z "$b" ] && continue
    [ "$b" = "$def" ] && continue
    [ "$b" = "$cur" ] && continue
    CAND+=("$b")
  done < <(git for-each-ref --format='%(refname:short)' --merged "$defref" refs/heads 2>/dev/null)

  if [ "${#CAND[@]}" -eq 0 ]; then
    printf "  ${G}✓ nothing to tidy${X} ${DIM}(no merged local branches besides %s%s)${X}\n\n" \
      "$def" "$([ "$cur" != "$def" ] && echo " and the current branch")"
    return 0
  fi

  for b in "${CAND[@]}"; do
    local ts; ts="$(git log -1 --format=%ct "$b" 2>/dev/null)"
    printf "    ${DIM}∙${X} %-30s ${G}merged${X} ${DIM}· %s${X}\n" "$b" "$(age_short "${ts:-0}")"
  done

  # "branch" pluralizes to "branches", which plural()'s bare -s can't do.
  local nb="${#CAND[@]}" noun; [ "$nb" = 1 ] && noun="branch" || noun="branches"

  if [ "$APPLY" != 1 ]; then
    printf "\n  ${DIM}%d merged %s · 'vegtam tidy --apply' deletes them (git branch -d — never the default or current branch, never anything on the remote)${X}\n\n" \
      "$nb" "$noun"
    return 0
  fi

  printf "\n"
  if [ "$YES" != 1 ] && ! confirm "delete $nb merged $noun?"; then
    printf "  ${DIM}aborted — nothing deleted.${X}\n\n"; return 0
  fi
  local deleted=0 failed=0
  for b in "${CAND[@]}"; do
    # -d (not -D) is the safety net: git refuses to delete anything not fully merged.
    if git branch -d "$b" >/dev/null 2>&1; then printf "  ${G}✓ deleted${X} %s\n" "$b"; deleted=$((deleted+1))
    else printf "  ${R}✗ couldn't delete${X} %s ${DIM}(not fully merged?)${X}\n" "$b"; failed=$((failed+1)); fi
  done
  printf "\n  ${BD}%d deleted${X}%s\n\n" "$deleted" "$([ "$failed" -gt 0 ] && printf " ${DIM}·${X} ${R}%d failed${X}" "$failed")"
}

# ── branch — create + switch to a branch (or just switch if it already exists) ──
cmd_branch(){
  is_help "${1:-}" && { help_branch; return 0; }
  local name="" a
  for a in "$@"; do case "$a" in
    -*) printf "  ${Y}ignoring unknown option: %s${X}\n" "$a";;
    *) [ -z "$name" ] && name="$a";;
  esac; done
  resolve_repo || return 1
  [ -z "$name" ] && { printf "\n  ${R}usage:${X} vegtam branch <name>\n\n"; return 1; }

  # If it already exists, switch to it rather than fail — the intent is "put me on <name>".
  if git rev-parse --verify -q "refs/heads/$name" >/dev/null 2>&1; then
    if git checkout -q "$name" 2>/dev/null; then
      printf "\n  ${G}✓ switched to${X} ${C}${BD}%s${X} ${DIM}(already existed)${X}\n\n" "$name"
    else
      printf "\n  ${R}✗ couldn't switch to %s${X} ${DIM}(uncommitted changes in the way — commit or stash first).${X}\n\n" "$name"; return 1
    fi
    return 0
  fi
  if git checkout -q -b "$name" 2>/dev/null; then
    printf "\n  ${G}✓ created + switched to${X} ${C}${BD}%s${X} ${DIM}(from %s)${X}\n\n" "$name" "$(git rev-parse --abbrev-ref '@{-1}' 2>/dev/null || echo HEAD)"
  else
    printf "\n  ${R}✗ couldn't create %s${X} ${DIM}(invalid branch name, or uncommitted changes in the way).${X}\n\n" "$name"; return 1
  fi
}

# ── pr — open a PR from the current branch (a thin wrapper over gh pr create) ──
# gh already does the hard parts well — pushing the branch if needed, the fork
# flow in a repo you can't push to, and prompting for title/body — so we guard the
# obvious mistakes and hand off, passing through any extra flags (--fill, --draft…).
cmd_pr(){
  is_help "${1:-}" && { help_pr; return 0; }
  resolve_repo || return 1
  [ -z "$SLUG" ] && { printf "\n  ${R}no github.com remote${X} ${DIM}— 'vegtam pr' opens a pull request on GitHub.${X}\n\n"; return 1; }
  have gh || { printf "\n  ${R}gh not installed${X} ${DIM}— 'vegtam pr' wraps 'gh pr create'.${X}\n\n"; return 1; }

  local branch def; branch="$(git symbolic-ref --short HEAD 2>/dev/null || echo detached)"; def="$(default_branch)"
  [ "$branch" = detached ] && { printf "\n  ${R}detached HEAD${X} ${DIM}— check out a branch first.${X}\n\n"; return 1; }
  if [ "$branch" = "$def" ]; then
    printf "\n  ${Y}you're on the default branch (%s)${X} ${DIM}— make a feature branch first:${X}  ${BD}vegtam branch <name>${X}\n\n" "$def"
    return 1
  fi

  # Refuse early if the branch has no commits the base doesn't already have — otherwise
  # gh pushes the branch and prompts for a title before discovering there's nothing to
  # open ("No commits between …"). Compare against origin/<default> (what GitHub compares),
  # falling back to the local default; only a *successful* zero count refuses, so a base
  # we can't resolve just hands off to gh as before. Uncommitted changes don't count —
  # a PR is made of commits.
  local base ahead
  base="$(default_ref "$def")"
  if [ "$base" != "HEAD" ] && ahead="$(git rev-list --count "$base..HEAD" 2>/dev/null)" && [ "$ahead" -eq 0 ]; then
    printf "\n  ${Y}nothing to open a PR for${X} ${DIM}— %s has no commits that %s doesn't already have.${X}\n" "$branch" "$base"
    printf "  ${DIM}commit your work first%s, then run 'vegtam pr' again.${X}\n\n" \
      "$([ -n "$(git status --porcelain 2>/dev/null)" ] && printf ' (your changes are still uncommitted)')"
    return 1
  fi

  printf "\n  ${BD}vegtam pr${X}  ${DIM}·  %s  ·  %s → %s${X}\n" "$SLUG" "$branch" "$def"
  printf "  ${DIM}handing off to 'gh pr create' — it pushes the branch if needed, and prompts for the rest.${X}\n\n"
  gh pr create "$@"
}

